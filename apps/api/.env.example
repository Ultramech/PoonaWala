# ========================================
# GoldEye Backend Configuration
# Copy this file to .env and fill in values
# ========================================

# ─── VLM Configuration (for S2, S8 VLM fallback) ─────────────────
# Options: http://localhost:11434/v1 (vLLM), Groq, Ollama, RunPod
VLM_API_URL=http://localhost:11434/v1
VLM_MODEL=qwen2.5vl
VLM_TIMEOUT_S=30
VLM_API_KEY=

# ─── Gemini API Configuration (PRIMARY for S3, S7, S11, fallbacks) ─
# Get key from: https://ai.google.dev/
GEMINI_API_KEY=AIzaSyCzgYb6vQEe2O7ux61F0y2ZF6YjqlOMNXI

# ─── Database Configuration ──────────────────────────────────────
# SQLite for dev, PostgreSQL for production
DATABASE_URL=sqlite:///./goldeye.db
# For Postgres: postgresql+asyncpg://user:password@localhost:5432/goldeye

# ─── Redis Configuration (for caching, rate limiting) ────────────
REDIS_URL=redis://localhost:6379

# ─── Application Settings ───────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-here

# ─── Feature Flags ─────────────────────────────────────────────
ENABLE_GEMINI=true
ENABLE_VLM_FALLBACK=true
